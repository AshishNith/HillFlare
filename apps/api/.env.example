NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://localhost:27017/hillflare
JWT_SECRET=change_me
OTP_SECRET=dev_otp_secret
CORS_ORIGIN=*

# SMTP settings for OTP emails (use Gmail: smtp.gmail.com with App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=HillFlare <your-email@gmail.com>
